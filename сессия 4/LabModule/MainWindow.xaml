<Window x:Class="LabModule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль лаборатории" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    
    <Grid Background="#F0F3F5">
        
        <!-- Панель входа -->
        <Grid x:Name="LoginPanel">
            <Border Width="400" Background="White" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel Margin="25">
                    <TextBlock Text="🧪 Модуль лаборатории" FontSize="22" FontWeight="Bold" 
                               Foreground="#2E86C1" HorizontalAlignment="Center" Margin="0,20"/>
                    <TextBlock Text="Вход в систему" FontSize="14" 
                               Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,5"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <TextBlock Text="Электронная почта" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBox x:Name="TxtLoginEmail" Height="35"/>
                    
                    <TextBlock Text="Пароль" FontWeight="Bold" Margin="0,15,0,0"/>
                    <PasswordBox x:Name="TxtLoginPassword" Height="35"/>
                    
                    <Button x:Name="BtnLogin" Content="ВОЙТИ" Background="#2E86C1" Foreground="White" 
                            Height="40" Margin="0,20"/>
                    
                    <Button x:Name="BtnShowRegister" Content="РЕГИСТРАЦИЯ" 
                            Background="#95A5A6" Foreground="White" Height="35"/>
                    
                    <TextBlock x:Name="TxtLoginError" Foreground="Red" TextWrapping="Wrap" 
                               HorizontalAlignment="Center" Margin="0,10"/>
                    
                    <Separator Margin="0,10"/>
                    
                    <Button x:Name="BtnGoToTechModule" Content="🏭 Модуль технолога" 
                            Background="#95A5A6" Foreground="White" Height="35"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Панель регистрации -->
        <Grid x:Name="RegisterPanel" Visibility="Collapsed">
            <Border Width="450" Background="White" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel Margin="25">
                    <TextBlock Text="📝 Регистрация" FontSize="22" FontWeight="Bold" 
                               Foreground="#2E86C1" HorizontalAlignment="Center" Margin="0,20"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <TextBlock Text="Электронная почта" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBox x:Name="TxtRegEmail" Height="35"/>
                    
                    <TextBlock Text="Пароль" FontWeight="Bold" Margin="0,15,0,0"/>
                    <PasswordBox x:Name="TxtRegPassword" Height="35"/>
                    
                    <TextBlock Text="Подтверждение" FontWeight="Bold" Margin="0,15,0,0"/>
                    <PasswordBox x:Name="TxtRegConfirmPassword" Height="35"/>
                    
                    <TextBlock Text="ФИО" FontWeight="Bold" Margin="0,15,0,0"/>
                    <TextBox x:Name="TxtRegFullName" Height="35"/>
                    
                    <TextBlock Text="Должность" FontWeight="Bold" Margin="0,15,0,0"/>
                    <ComboBox x:Name="CmbRegRole" Height="35" SelectedIndex="0">
                        <ComboBoxItem Content="Лаборант"/>
                        <ComboBoxItem Content="Старший лаборант"/>
                        <ComboBoxItem Content="Заведующий лабораторией"/>
                    </ComboBox>
                    
                    <Button x:Name="BtnRegister" Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                            Background="#27AE60" Foreground="White" Height="40" Margin="0,20"/>
                    
                    <Button x:Name="BtnShowLogin" Content="НАЗАД" 
                            Background="#95A5A6" Foreground="White" Height="35"/>
                    
                    <TextBlock x:Name="TxtRegError" Foreground="Red" TextWrapping="Wrap" 
                               HorizontalAlignment="Center" Margin="0,10"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Главная панель -->
        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="#2E86C1" Padding="15">
                <Grid>
                    <TextBlock Text="Модуль лаборатории" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtUserInfo" Foreground="White" Margin="200,0,0,0" VerticalAlignment="Center"/>
                    <Button x:Name="BtnLogout" Content="Выход" Width="80" Background="#E74C3C" 
                            Foreground="White" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
            
            <!-- Статистика -->
            <Border Grid.Row="1" Background="White" Margin="10,10,10,0" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#3498DB" CornerRadius="6" Margin="5" Padding="10">
                        <TextBlock x:Name="TxtPendingBatches" Text="На контроле: 0" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="1" Background="#27AE60" CornerRadius="6" Margin="5" Padding="10">
                        <TextBlock x:Name="TxtCompletedBatches" Text="Проверено: 0" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="2" Background="#F39C12" CornerRadius="6" Margin="5" Padding="10">
                        <TextBlock x:Name="TxtTotalTests" Text="Испытаний: 0" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="3" Background="#8E44AD" CornerRadius="6" Margin="5" Padding="10">
                        <TextBlock x:Name="TxtApprovedTests" Text="Одобрено: 0" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Вкладки -->
            <TabControl x:Name="MainTabControl" Grid.Row="2" Margin="10">
                
                <!-- ПАРТИИ -->
                <TabItem Header="📦 Партии">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <Button x:Name="BtnRefreshBatches" Content="🔄 Обновить" Background="#3498DB" Foreground="White" Width="120" Height="35"/>
                                <Button x:Name="BtnStartTest" Content="🔬 Начать испытание" Background="#27AE60" Foreground="White" Width="150" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgBatches" Grid.Row="1" Margin="5" AutoGenerateColumns="True" 
                                  SelectionChanged="DgBatches_SelectionChanged" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                
                <!-- ИСПЫТАНИЯ -->
                <TabItem Header="🔬 Испытания">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <Button x:Name="BtnRefreshQuality" Content="🔄 Обновить" Background="#3498DB" Foreground="White" Width="120" Height="35"/>
                                <Button x:Name="BtnAddQuality" Content="➕ Добавить испытание" Background="#27AE60" Foreground="White" Width="150" Height="35"/>
                                <Button x:Name="BtnProcessSelected" Content="🔧 Обработать выбранное" Background="#F39C12" Foreground="White" Width="180" Height="35"/>
                            </WrapPanel>
                        </Border>
                        
                        <DataGrid x:Name="DgQualityControls" Grid.Row="1" Margin="5" AutoGenerateColumns="False" 
                                  AlternatingRowBackground="#F2F3F4" IsReadOnly="True"
                                  SelectionChanged="DgQualityControls_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="ID партии" Binding="{Binding BatchId}" Width="80"/>
                                <DataGridTextColumn Header="ID сырья" Binding="{Binding RawMaterialBatchId}" Width="80"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                                <DataGridTextColumn Header="Дата анализа" Binding="{Binding AnalysisDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="140"/>
                                <DataGridTextColumn Header="Тип образца" Binding="{Binding SampleType}" Width="120"/>
                                <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" Width="150"/>
                                <DataGridTextColumn Header="Значение" Binding="{Binding MeasuredValue}" Width="80"/>
                                <DataGridTextColumn Header="Норматив" Binding="{Binding StandardValue}" Width="80"/>
                                <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="80"/>
                                <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" Width="80"/>
                                <DataGridTextColumn Header="Комментарий" Binding="{Binding AnalystComment}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                
                <!-- ПРОВЕДЕНИЕ ИСПЫТАНИЙ -->
                <TabItem Header="⚙️ Проведение испытаний">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Испытание ID:" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtQualityId" Grid.Column="1" Margin="10,0,20,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Партия:" FontWeight="Bold" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtSelectedBatchInfo" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Тип образца:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbSampleType" Grid.Row="0" Grid.Column="1" Width="180" Height="35" Margin="5" SelectedIndex="0">
                                    <ComboBoxItem Content="Готовая продукция" IsSelected="True"/>
                                    <ComboBoxItem Content="Сырье"/>
                                    <ComboBoxItem Content="Полуфабрикат"/>
                                </ComboBox>
                                
                                <TextBlock Text="Параметр:" FontWeight="Bold" Grid.Row="1" Margin="5" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbParameter" Grid.Row="1" Grid.Column="1" Width="180" Height="35" Margin="5" SelectedIndex="0">
                                    <ComboBoxItem Content="Концентрация"/>
                                    <ComboBoxItem Content="Влажность"/>
                                    <ComboBoxItem Content="pH"/>
                                    <ComboBoxItem Content="Плотность"/>
                                    <ComboBoxItem Content="Вязкость"/>
                                </ComboBox>
                                
                                <TextBlock Text="Значение:" FontWeight="Bold" Grid.Row="2" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtMeasuredValue" Grid.Row="2" Grid.Column="1" Width="180" Height="35" Margin="5"/>
                                <TextBlock x:Name="TxtValidationResult" Grid.Row="2" Grid.Column="2" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>
                                
                                <TextBlock Text="Норматив:" FontWeight="Bold" Grid.Row="3" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtStandardValue" Grid.Row="3" Grid.Column="1" Width="180" Height="35" Margin="5" Text="95.0-98.0"/>
                                <Button x:Name="BtnValidateTest" Grid.Row="3" Grid.Column="2" Content="✅ Проверить" Background="#3498DB" Foreground="White" Width="120" Height="35" Margin="5"/>
                            </Grid>
                        </Border>
                        
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Комментарий лаборанта:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtTestComment" Grid.Row="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </Grid>
                        </Border>
                        
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnApproveTest" Content="✅ ОДОБРИТЬ" Background="#27AE60" Foreground="White" Width="150" Height="45" Margin="10" FontSize="14"/>
                                <Button x:Name="BtnBlockTest" Content="❌ ЗАБРАКОВАТЬ" Background="#E74C3C" Foreground="White" Width="150" Height="45" Margin="10" FontSize="14"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#FFF3CD" CornerRadius="6" Padding="10">
                            <TextBlock Text="💡 Выберите испытание из списка, заполните параметры, проверьте и примите решение" 
                                       Foreground="#856404" FontSize="12" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </TabItem>
                
                <!-- ОТКЛОНЕНИЯ -->
                <TabItem Header="⚠️ Отклонения">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBox x:Name="TxtDevBatchId" Width="100" Tag="ID партии" Margin="5"/>
                                <TextBox x:Name="TxtDevDesc" Width="250" Tag="Описание" Margin="5"/>
                                <ComboBox x:Name="CmbDevSeverity" Width="120" Margin="5" SelectedIndex="2">
                                    <ComboBoxItem Content="Низкая"/>
                                    <ComboBoxItem Content="Средняя"/>
                                    <ComboBoxItem Content="Высокая"/>
                                    <ComboBoxItem Content="Критическая"/>
                                </ComboBox>
                                <Button x:Name="BtnAddDeviation" Content="Добавить" Background="#E74C3C" Foreground="White" Width="100" Margin="5"/>
                                <Button x:Name="BtnRefreshDeviations" Content="Обновить" Background="#3498DB" Foreground="White" Width="100" Margin="5"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgDeviations" Grid.Row="1" Margin="5" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                
                <!-- ИСТОРИЯ -->
                <TabItem Header="📋 История">
                    <DataGrid x:Name="DgHistory" Margin="5" AutoGenerateColumns="True" IsReadOnly="True"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>