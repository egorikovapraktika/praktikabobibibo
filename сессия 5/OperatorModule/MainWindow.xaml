<Window x:Class="OperatorModule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль аппаратчика - Рабочее место оператора" 
        Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AlternatingRowBackground" Value="#F2F3F4"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F0F3F5">
        
        <!-- ПАНЕЛЬ ВХОДА -->
        <Grid x:Name="LoginPanel" Background="#F0F3F5">
            <Border Width="450" Background="White" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel Margin="25">
                    <TextBlock Text="🏭 Модуль аппаратчика" FontSize="24" FontWeight="Bold" 
                               Foreground="#2E86C1" HorizontalAlignment="Center" Margin="0,20"/>
                    <TextBlock Text="Рабочее место оператора" FontSize="14" 
                               Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,5"/>
                    
                    <Separator Margin="0,20" Background="#BDC3C7"/>
                    
                    <TextBlock Text="Электронная почта" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
                    <TextBox x:Name="TxtLoginEmail" Height="38" FontSize="14"/>
                    
                    <TextBlock Text="Пароль" FontWeight="Bold" FontSize="14" Margin="0,15,0,0"/>
                    <PasswordBox x:Name="TxtLoginPassword" Height="38" FontSize="14"/>
                    
                    <Button x:Name="BtnLogin" Content="🔓 ВОЙТИ" Background="#2E86C1" Foreground="White" 
                            Height="45" Margin="0,25,0,10" FontSize="15"/>
                    
                    <Button x:Name="BtnShowRegister" Content="📝 РЕГИСТРАЦИЯ" 
                            Background="#95A5A6" Foreground="White" Height="35" Margin="0,5"/>
                    
                    <TextBlock x:Name="TxtLoginError" Foreground="Red" FontSize="13"
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,10"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- ПАНЕЛЬ РЕГИСТРАЦИИ -->
        <Grid x:Name="RegisterPanel" Background="#F0F3F5" Visibility="Collapsed">
            <Border Width="500" Background="White" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <ScrollViewer MaxHeight="600">
                    <StackPanel Margin="25">
                        <TextBlock Text="📝 Регистрация нового оператора" FontSize="22" FontWeight="Bold" 
                                   Foreground="#2E86C1" HorizontalAlignment="Center" Margin="0,20"/>
                        
                        <Separator Margin="0,15" Background="#BDC3C7"/>
                        
                        <TextBlock Text="Электронная почта" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtRegEmail" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Пароль" FontWeight="Bold" FontSize="14" Margin="0,15,0,0"/>
                        <PasswordBox x:Name="TxtRegPassword" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Подтверждение пароля" FontWeight="Bold" FontSize="14" Margin="0,15,0,0"/>
                        <PasswordBox x:Name="TxtRegConfirmPassword" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Фамилия Имя Отчество" FontWeight="Bold" FontSize="14" Margin="0,15,0,0"/>
                        <TextBox x:Name="TxtRegFullName" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Должность" FontWeight="Bold" FontSize="14" Margin="0,15,0,0"/>
                        <ComboBox x:Name="CmbRegRole" Height="38" FontSize="14" SelectedIndex="0">
                            <ComboBoxItem Content="Оператор линии"/>
                            <ComboBoxItem Content="Старший оператор"/>
                            <ComboBoxItem Content="Мастер смены"/>
                            <ComboBoxItem Content="Начальник цеха"/>
                        </ComboBox>
                        
                        <Button x:Name="BtnRegister" Content="✅ ЗАРЕГИСТРИРОВАТЬСЯ" 
                                Background="#27AE60" Foreground="White" Height="45" Margin="0,25,0,10" FontSize="15"/>
                        
                        <Button x:Name="BtnShowLogin" Content="◀ ВЕРНУТЬСЯ К ВХОДУ" 
                                Background="#95A5A6" Foreground="White" Height="35"/>
                        
                        <TextBlock x:Name="TxtRegError" Foreground="Red" FontSize="13"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        
        <!-- ГЛАВНАЯ ПАНЕЛЬ -->
        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="#2E86C1" Padding="15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🏭 Модуль аппаратчика" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtUserInfo" Text="" Foreground="#D4E6F1" Margin="25,0,0,0" FontSize="14"/>
                    </StackPanel>
                    <Button x:Name="BtnLogout" Content="🚪 Выход" Width="100" Height="35" Background="#E74C3C" 
                            Foreground="White" HorizontalAlignment="Right" FontSize="13"/>
                </Grid>
            </Border>
            
            <!-- Контент -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Список партий -->
                <Grid x:Name="BatchesPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 Активные партии" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button x:Name="BtnRefreshBatches" Content="🔄 Обновить" Background="#3498DB" Foreground="White" 
                                    Width="100" Height="35" Margin="20,0,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <DataGrid x:Name="DgBatches" Grid.Row="1" AutoGenerateColumns="True" 
                              SelectionChanged="DgBatches_SelectionChanged" IsReadOnly="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="40"/>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
                
                <!-- Программа партии -->
                <Grid x:Name="ProgramPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Информация о партии -->
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Партия:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBatchNumber" Grid.Column="1" Margin="10,0,20,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Статус:" FontWeight="Bold" Grid.Column="2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBatchStatus" Grid.Column="3" Margin="10,0,20,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Продукт:" FontWeight="Bold" Grid.Column="4" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtProductName" Grid.Column="5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Текущий шаг -->
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="Текущий шаг:" FontWeight="Bold" FontSize="14" Margin="5"/>
                            <TextBlock x:Name="TxtCurrentStep" Grid.Column="1" FontSize="14" Margin="5" FontWeight="Bold"/>
                            
                            <TextBlock Text="Инструкция:" FontWeight="Bold" Grid.Row="1" Margin="5" VerticalAlignment="Top"/>
                            <TextBlock x:Name="TxtInstruction" Grid.Row="1" Grid.Column="1" Margin="5" TextWrapping="Wrap" VerticalAlignment="Top"/>
                            
                            <TextBlock Text="Температура:" FontWeight="Bold" Grid.Row="2" Margin="5" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                <TextBlock Text="План:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtPlannedTemp" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Факт:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtActualTemp" Width="80" Height="30" Margin="0,0,15,0"/>
                                <TextBlock Text="°C" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Text="Давление:" FontWeight="Bold" Grid.Row="3" Margin="5" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                <TextBlock Text="План:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtPlannedPressure" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Факт:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtActualPressure" Width="80" Height="30" Margin="0,0,15,0"/>
                                <TextBlock Text="бар" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Text="Длительность:" FontWeight="Bold" Grid.Row="4" Margin="5" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                <TextBlock Text="План:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtPlannedDuration" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Факт:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtActualDuration" Width="80" Height="30" Margin="0,0,15,0"/>
                                <TextBlock Text="мин" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Список шагов -->
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="📋 Последовательность шагов" FontWeight="Bold" FontSize="14" Margin="5,0,0,10"/>
                            <DataGrid x:Name="DgSteps" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" Height="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="№" Binding="{Binding StepOrder}" Width="50"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding StepName}" Width="150"/>
                                    <DataGridTextColumn Header="Тип" Binding="{Binding StepType}" Width="100"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    
                    <!-- Кнопки управления -->
                    <Border Background="White" CornerRadius="8" Padding="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnStartStep" Content="▶ НАЧАТЬ ШАГ" Background="#27AE60" Foreground="White" Width="150" Height="45" Margin="10" FontSize="14"/>
                            <Button x:Name="BtnCompleteStep" Content="✅ ЗАВЕРШИТЬ ШАГ" Background="#3498DB" Foreground="White" Width="170" Height="45" Margin="10" FontSize="14"/>
                            <Button x:Name="BtnReportDeviation" Content="⚠️ СООБЩИТЬ ОБ ОТКЛОНЕНИИ" Background="#E74C3C" Foreground="White" Width="220" Height="45" Margin="10" FontSize="14"/>
                            <Button x:Name="BtnBackToBatches" Content="◀ НАЗАД К ПАРТИЯМ" Background="#95A5A6" Foreground="White" Width="180" Height="45" Margin="10" FontSize="14"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>