<Window x:Class="TechModule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль технолога - Система управления производством" 
        Height="800" Width="1200" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AlternatingRowBackground" Value="#F2F3F4"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F0F3F5">
        
        <!-- ==================== ПАНЕЛЬ ВХОДА С КАПЧЕЙ ==================== -->
        <Grid x:Name="LoginPanel" Background="#F0F3F5">
            <Border Width="500" Background="White" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel Margin="30">
                    <TextBlock Text="🧪 Модуль технолога" FontSize="26" FontWeight="Bold" 
                               Foreground="#2E86C1" HorizontalAlignment="Center" Margin="0,20"/>
                    <TextBlock Text="Вход в систему" FontSize="15" 
                               Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,5"/>
                    
                    <Separator Margin="0,20" Background="#BDC3C7"/>
                    
                    <TextBlock Text="Электронная почта" Margin="0,10,0,0" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtLoginEmail" Height="38" FontSize="14"/>
                    
                    <TextBlock Text="Пароль" Margin="0,15,0,0" FontWeight="Bold" FontSize="14"/>
                    <PasswordBox x:Name="TxtLoginPassword" Height="38" FontSize="14"/>
                    
                    <!-- УВЕЛИЧЕННАЯ КАПЧА -->
                    <TextBlock Text="Введите код с картинки" Margin="0,20,0,0" FontWeight="Bold" FontSize="14"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCaptcha" Grid.Column="0" Height="45" FontSize="18" FontWeight="Bold"/>
                        <Button x:Name="BtnRefreshCaptcha" Grid.Column="1" Content="🔄 Обновить" 
                                Width="90" Height="45" Margin="10,0,0,0" Background="#95A5A6" Foreground="White" FontSize="13"/>
                    </Grid>
                    
                    <!-- УВЕЛИЧЕННОЕ ИЗОБРАЖЕНИЕ КАПЧИ -->
                    <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Background="White">
                        <Image x:Name="ImgCaptcha" Height="120" Stretch="UniformToFill" Margin="10"/>
                    </Border>
                    
                    <Button x:Name="BtnLogin" Content="🔓 ВОЙТИ" Background="#2E86C1" Foreground="White" 
                            Height="45" Margin="0,25,0,10" FontSize="15"/>
                    
                    <Button x:Name="BtnShowRegister" Content="📝 РЕГИСТРАЦИЯ" 
                            Background="#95A5A6" Foreground="White" Height="40"/>
                    
                    <TextBlock x:Name="TxtLoginError" Foreground="Red" FontSize="13"
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- ==================== ПАНЕЛЬ РЕГИСТРАЦИИ С УВЕЛИЧЕННОЙ КАПЧЕЙ ==================== -->
        <Grid x:Name="RegisterPanel" Background="#F0F3F5" Visibility="Collapsed">
            <Border Width="550" Background="White" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <ScrollViewer MaxHeight="700">
                    <StackPanel Margin="30">
                        <TextBlock Text="📝 Регистрация нового пользователя" FontSize="24" FontWeight="Bold" 
                                   Foreground="#2E86C1" HorizontalAlignment="Center" Margin="0,20"/>
                        
                        <Separator Margin="0,15" Background="#BDC3C7"/>
                        
                        <TextBlock Text="Электронная почта" Margin="0,10,0,0" FontWeight="Bold" FontSize="14"/>
                        <TextBox x:Name="TxtRegEmail" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Пароль" Margin="0,15,0,0" FontWeight="Bold" FontSize="14"/>
                        <PasswordBox x:Name="TxtRegPassword" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Подтверждение пароля" Margin="0,15,0,0" FontWeight="Bold" FontSize="14"/>
                        <PasswordBox x:Name="TxtRegConfirmPassword" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Фамилия Имя Отчество" Margin="0,15,0,0" FontWeight="Bold" FontSize="14"/>
                        <TextBox x:Name="TxtRegFullName" Height="38" FontSize="14"/>
                        
                        <TextBlock Text="Должность" Margin="0,15,0,0" FontWeight="Bold" FontSize="14"/>
                        <ComboBox x:Name="CmbRegRole" Height="38" FontSize="14" SelectedIndex="0">
                            <ComboBoxItem Content="Технолог"/>
                            <ComboBoxItem Content="Оператор"/>
                            <ComboBoxItem Content="Лаборант"/>
                            <ComboBoxItem Content="Администратор"/>
                            <ComboBoxItem Content="Начальник производства"/>
                        </ComboBox>
                        
                        <!-- УВЕЛИЧЕННАЯ КАПЧА -->
                        <TextBlock Text="Введите код с картинки" Margin="0,20,0,0" FontWeight="Bold" FontSize="14"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtRegCaptcha" Grid.Column="0" Height="45" FontSize="18" FontWeight="Bold"/>
                            <Button x:Name="BtnRefreshRegCaptcha" Grid.Column="1" Content="🔄 Обновить" 
                                    Width="90" Height="45" Margin="10,0,0,0" Background="#95A5A6" Foreground="White" FontSize="13"/>
                        </Grid>
                        
                        <!-- УВЕЛИЧЕННОЕ ИЗОБРАЖЕНИЕ КАПЧИ -->
                        <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Background="White">
                            <Image x:Name="ImgRegCaptcha" Height="120" Stretch="UniformToFill" Margin="10"/>
                        </Border>
                        
                        <Button x:Name="BtnRegister" Content="✅ ЗАРЕГИСТРИРОВАТЬСЯ" 
                                Background="#27AE60" Foreground="White" Height="45" Margin="0,25,0,10" FontSize="15"/>
                        
                        <Button x:Name="BtnShowLogin" Content="◀ ВЕРНУТЬСЯ К ВХОДУ" 
                                Background="#95A5A6" Foreground="White" Height="40"/>
                        
                        <TextBlock x:Name="TxtRegError" Foreground="Red" FontSize="13"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        
        <!-- ==================== ГЛАВНАЯ ПАНЕЛЬ ==================== -->
        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="#2E86C1" Padding="15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🏭 Модуль технолога" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtUserInfo" Text="" Foreground="#D4E6F1" Margin="25,0,0,0" FontSize="14"/>
                    </StackPanel>
                    <Button x:Name="BtnLogout" Content="🚪 Выход" Width="100" Height="35" Background="#E74C3C" 
                            Foreground="White" HorizontalAlignment="Right" FontSize="13"/>
                </Grid>
            </Border>
            
            <!-- Панель статистики -->
            <Border Grid.Row="1" Background="White" Margin="10,10,10,0" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#3498DB" CornerRadius="6" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="📊 Активных партий" Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="TxtActiveBatches" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#27AE60" CornerRadius="6" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="✅ Завершено" Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="TxtCompletedBatches" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#F39C12" CornerRadius="6" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="📋 Активных заказов" Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="TxtPendingOrders" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#E74C3C" CornerRadius="6" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="⚠️ Отклонений" Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="TxtDeviations" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="#8E44AD" CornerRadius="6" Margin="5" Padding="5">
                        <Button x:Name="BtnRefreshAll" Content="🔄 Обновить все" Background="#8E44AD" 
                                Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13" Height="55"/>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Вкладки -->
            <TabControl Grid.Row="2" Margin="10">
                
                <!-- ПРОДУКЦИЯ -->
                <TabItem Header="📦 Продукция">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBox x:Name="TxtProductName" Width="220" Tag="Название продукта" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtProductType" Width="160" Tag="Тип" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtProductForm" Width="160" Tag="Форма выпуска" Margin="0,0,10,0" Height="35"/>
                                <Button x:Name="BtnAddProduct" Content="➕ Добавить" Background="#27AE60" Foreground="White" Width="120" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgProducts" Grid.Row="1" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
                
                <!-- РЕЦЕПТУРЫ -->
                <TabItem Header="📖 Рецептуры">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBox x:Name="TxtRecipeName" Width="220" Tag="Название рецептуры" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtRecipeProduct" Width="160" Tag="Продукт" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtRecipeOutput" Width="130" Tag="Выход (кг)" Margin="0,0,10,0" Height="35"/>
                                <Button x:Name="BtnAddRecipe" Content="➕ Добавить" Background="#27AE60" Foreground="White" Width="120" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgRecipes" Grid.Row="1" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
                
                <!-- ТЕХНОЛОГИЧЕСКИЕ КАРТЫ -->
                <TabItem Header="🗺️ Технологические карты">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBox x:Name="TxtTechMapName" Width="260" Tag="Название техкарты" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtTechMapRecipeId" Width="120" Tag="ID рецептуры" Margin="0,0,10,0" Height="35"/>
                                <Button x:Name="BtnAddTechMap" Content="➕ Добавить" Background="#27AE60" Foreground="White" Width="120" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgTechMaps" Grid.Row="1" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
                
                <!-- ПРОИЗВОДСТВЕННЫЕ ЗАКАЗЫ -->
                <TabItem Header="📋 Производственные заказы">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBox x:Name="TxtOrderRecipeId" Width="110" Tag="ID рецептуры" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtOrderQty" Width="130" Tag="Количество (кг)" Margin="0,0,10,0" Height="35"/>
                                <DatePicker x:Name="DtOrderStart" Width="140" Margin="0,0,10,0" Height="35"/>
                                <DatePicker x:Name="DtOrderEnd" Width="140" Margin="0,0,10,0" Height="35"/>
                                <Button x:Name="BtnAddOrder" Content="➕ Создать заказ" Background="#27AE60" Foreground="White" Width="140" Height="35"/>
                                <Button x:Name="BtnStartBatch" Content="▶ Запустить партию" Background="#F39C12" Foreground="White" Width="150" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgOrders" Grid.Row="1" AutoGenerateColumns="True" SelectionChanged="DgOrders_SelectionChanged"/>
                    </Grid>
                </TabItem>
                
                <!-- ПРОИЗВОДСТВЕННЫЕ ПАРТИИ -->
                <TabItem Header="🏭 Производственные партии">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <Button x:Name="BtnRefreshBatches" Content="🔄 Обновить" Background="#3498DB" Foreground="White" Width="120" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgBatches" Grid.Row="1" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
                
                <!-- ОТКЛОНЕНИЯ -->
                <TabItem Header="⚠️ Отклонения и события">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBox x:Name="TxtDevBatchId" Width="110" Tag="ID партии" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtDevType" Width="160" Tag="Тип отклонения" Margin="0,0,10,0" Height="35"/>
                                <TextBox x:Name="TxtDevDesc" Width="270" Tag="Описание" Margin="0,0,10,0" Height="35"/>
                                <ComboBox x:Name="CmbDevSeverity" Width="130" Margin="0,0,10,0" Height="35">
                                    <ComboBoxItem Content="Низкая"/>
                                    <ComboBoxItem Content="Средняя"/>
                                    <ComboBoxItem Content="Высокая" IsSelected="True"/>
                                    <ComboBoxItem Content="Критическая"/>
                                </ComboBox>
                                <Button x:Name="BtnAddDeviation" Content="⚠️ Зафиксировать" Background="#E74C3C" Foreground="White" Width="150" Height="35"/>
                                <Button x:Name="BtnRefreshDeviations" Content="🔄 Обновить" Background="#3498DB" Foreground="White" Width="100" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgDeviations" Grid.Row="1" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
                
                <!-- УВЕДОМЛЕНИЯ -->
                <TabItem Header="🔔 Уведомления">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <Button x:Name="BtnRefreshNotifications" Content="🔄 Обновить уведомления" Background="#3498DB" Foreground="White" Width="180" Height="35"/>
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="DgNotifications" Grid.Row="1" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
                
                <!-- ОТЧЕТЫ -->
                <TabItem Header="📊 Отчеты и аналитика">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Background="White" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                                <DatePicker x:Name="DtReportFrom" Grid.Column="1" Width="140" Margin="0,0,10,0" Height="35"/>
                                <TextBlock Text="—" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                                <DatePicker x:Name="DtReportTo" Grid.Column="3" Width="140" Height="35"/>
                            </Grid>
                        </Border>
                        
                        <Border Background="White" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <WrapPanel>
                                <Button x:Name="BtnReportBatches" Content="📊 Отчет по партиям" Background="#3498DB" Foreground="White" Width="200" Height="40" Margin="0,0,10,0"/>
                                <Button x:Name="BtnReportDeviations" Content="⚠️ Отчет по отклонениям" Background="#E74C3C" Foreground="White" Width="220" Height="40" Margin="0,0,10,0"/>
                                <Button x:Name="BtnReportQuality" Content="🔬 Отчет по качеству" Background="#27AE60" Foreground="White" Width="200" Height="40"/>
                            </WrapPanel>
                        </Border>
                        
                        <TextBlock Grid.Row="2" Text="📈 Производственная статистика" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        
                        <DataGrid Grid.Row="3" x:Name="DgStats" AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>